# Core app
NODE_ENV=development
PORT=3001
API_PREFIX=api

# Database + cache
DATABASE_URL=postgresql://user:password@localhost:5432/textilebill

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=true
REDIS_TLS=false

# Auth/JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_TENANT_CREATION_PASSWORD=your_admin_creation_password

# Mail (Resend)
MAIL_ENABLED=true
MAIL_FROM=TextileBook <noreply@textilebook.app>
MAIL_RESEND_API_KEY=your_resend_api_key
MAIL_RESEND_FROM=TextileBook <noreply@textilebook.app>
MAIL_RESEND_REPLY_TO=
APP_URL=http://localhost:3000,http://127.0.0.1:3000
