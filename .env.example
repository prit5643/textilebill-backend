# Application
NODE_ENV=
PORT=
API_PREFIX=
APP_URL=
CORS_ORIGIN=
TRUST_PROXY=

# Database
# Runtime (Supabase pooled URL, port 6543)
DATABASE_URL=
# Optional for Prisma migrations (Supabase direct URL, port 5432)
DATABASE_DIRECT_URL=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
ADMIN_TENANT_CREATION_PASSWORD=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Mail (Nodemailer transport: smtp or gmail)
MAIL_ENABLED=
MAIL_TRANSPORT=

# SMTP mode (used when MAIL_TRANSPORT=smtp)
MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=
MAIL_USER=
MAIL_PASSWORD=

# Gmail mode (used when MAIL_TRANSPORT=gmail)
MAIL_GMAIL_USER=
MAIL_GMAIL_APP_PASSWORD=
MAIL_GMAIL_FROM=

# Sender (SMTP requires MAIL_FROM; Gmail can use MAIL_GMAIL_FROM or MAIL_FROM)
MAIL_FROM=

MAIL_ASYNC_QUEUE_ENABLED=
MAIL_SEND_TIMEOUT_MS=
MAIL_CONNECTION_TIMEOUT_MS=
MAIL_GREETING_TIMEOUT_MS=
MAIL_SOCKET_TIMEOUT_MS=
MAIL_TEST_TO=

# Rate Limiting
THROTTLE_TTL=
THROTTLE_LIMIT=

# App Encryption (for CompanySettings encrypted fields)
APP_SECRET_KEY=

# Bootstrap Configuration (First-time setup)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_TENANT_SLUG=
BOOTSTRAP_TENANT_NAME=
BOOTSTRAP_TENANT_EMAIL=
BOOTSTRAP_COMPANY_NAME=

# Optional Bootstrap Credentials
BOOTSTRAP_EWAYBILL_USERNAME=
BOOTSTRAP_EWAYBILL_PASSWORD=
BOOTSTRAP_EINVOICE_USERNAME=
BOOTSTRAP_EINVOICE_PASSWORD=
