# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/textilebill?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_TENANT_CREATION_PASSWORD=change-this-superadmin-action-password

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=textilebill-uploads

# Mail (Nodemailer transport: smtp or gmail)
MAIL_ENABLED=false
MAIL_TRANSPORT=smtp

# SMTP mode (used when MAIL_TRANSPORT=smtp)
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=

# Gmail mode (used when MAIL_TRANSPORT=gmail)
MAIL_GMAIL_USER=
MAIL_GMAIL_APP_PASSWORD=
MAIL_GMAIL_FROM=

# Sender (SMTP requires MAIL_FROM; Gmail can use MAIL_GMAIL_FROM or MAIL_FROM)
MAIL_FROM=

MAIL_ASYNC_QUEUE_ENABLED=false
MAIL_SEND_TIMEOUT_MS=10000
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_GREETING_TIMEOUT_MS=10000
MAIL_SOCKET_TIMEOUT_MS=10000
MAIL_TEST_TO=

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# App Encryption (for CompanySettings encrypted fields)
APP_SECRET_KEY=your-super-secret-app-key-change-this-in-production

# Bootstrap Configuration (First-time setup)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-strong-password
BOOTSTRAP_TENANT_SLUG=tv-root
BOOTSTRAP_TENANT_NAME=TextileBill Root
BOOTSTRAP_TENANT_EMAIL=root@textilebill.local
BOOTSTRAP_COMPANY_NAME=TextileBill Default Company

# Optional Bootstrap Credentials
BOOTSTRAP_EWAYBILL_USERNAME=
BOOTSTRAP_EWAYBILL_PASSWORD=
BOOTSTRAP_EINVOICE_USERNAME=
BOOTSTRAP_EINVOICE_PASSWORD=
