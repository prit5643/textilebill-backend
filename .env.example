# Application
NODE_ENV=
PORT=
API_PREFIX=
APP_URL=
TRUST_PROXY=

# Database
# Runtime (Supabase pooled URL, port 6543)
DATABASE_URL=
# Optional for Prisma migrations (Supabase direct URL, port 5432)
DATABASE_DIRECT_URL=

# Redis
# Enable/disable Redis (optional, auto-detected in production if REDIS_URL/REDIS_HOST exists)
REDIS_ENABLED=

# === HEROKU SETUP (Current) ===
# For Heroku Redis add-on, auto-set as REDIS env variable
# Use REDIS_URL for TLS connections (rediss://)
# Example: REDIS_URL=rediss://:password@host:25050
REDIS_URL=

# === EC2 SETUP (Future) ===
# For EC2 instance without TLS, use host/port/password
# Example (localhost): REDIS_HOST=localhost, REDIS_PORT=6379, REDIS_PASSWORD=
# Example (EC2): REDIS_HOST=redis.example.com, REDIS_PORT=6379, REDIS_PASSWORD=mypassword
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# Explicit TLS flag (auto-detected from rediss:// URL if not set)
# Set to 'true' for EC2 with TLS, 'false' for unencrypted connections
REDIS_TLS=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
ADMIN_TENANT_CREATION_PASSWORD=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Mail (Resend)
MAIL_ENABLED=
MAIL_FROM=
MAIL_RESEND_API_KEY=
MAIL_RESEND_FROM=
MAIL_RESEND_REPLY_TO=

MAIL_ASYNC_QUEUE_ENABLED=
MAIL_SEND_TIMEOUT_MS=
MAIL_MAX_SENDS_PER_PROCESS=
MAIL_TEST_TO=

# Rate Limiting
THROTTLE_TTL=
THROTTLE_LIMIT=

# App Encryption (for CompanySettings encrypted fields)
APP_SECRET_KEY=

# Bootstrap Configuration (First-time setup)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_TENANT_SLUG=
BOOTSTRAP_TENANT_NAME=
BOOTSTRAP_TENANT_EMAIL=
BOOTSTRAP_COMPANY_NAME=

# Optional Bootstrap Credentials
BOOTSTRAP_EWAYBILL_USERNAME=
BOOTSTRAP_EWAYBILL_PASSWORD=
BOOTSTRAP_EINVOICE_USERNAME=
BOOTSTRAP_EINVOICE_PASSWORD=
