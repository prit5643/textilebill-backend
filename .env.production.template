# ══════════════════════════════════════════════════════════════
# TextileBill Backend - Production Environment Template
# ══════════════════════════════════════════════════════════════
# Copy this file and configure for your Render deployment
# Add these variables in Render Dashboard → Environment Variables
# ══════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=api
APP_URL=https://your-frontend-name.vercel.app

# IMPORTANT: Update this with your actual Vercel frontend URL after deployment
CORS_ORIGIN=https://your-frontend-name.vercel.app

# ─── Database (Supabase) ───────────────────────────────────────
# IMPORTANT: Use POOLED connection (port 6543) for production runtime
# Get this from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ─── Redis ─────────────────────────────────────────────────────
# Option 1: Upstash Redis (Recommended - https://upstash.com/)
# Option 2: Render Redis (Dashboard → New → Redis)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ─── JWT Secrets ───────────────────────────────────────────────
# IMPORTANT: Generate secure random strings for production
# Use: openssl rand -base64 32
# NEVER use development secrets in production!
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# Admin password for creating tenants
ADMIN_TENANT_CREATION_PASSWORD=REPLACE_WITH_SECURE_ADMIN_PASSWORD

# ─── AWS S3 (Optional - for file uploads) ─────────────────────
# Leave empty if not using S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=textilebill-uploads-prod

# ─── Mail (Resend) ─────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
# Verify your sending domain in Resend before using custom from addresses
MAIL_ENABLED=true
MAIL_FROM=TextileBill <onboarding@resend.dev>
MAIL_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_RESEND_FROM=TextileBill <billing@yourdomain.com>
MAIL_RESEND_REPLY_TO=support@yourdomain.com
MAIL_SEND_TIMEOUT_MS=10000
MAIL_MAX_SENDS_PER_PROCESS=5000

# Test email recipient (optional)
MAIL_TEST_TO=

# ─── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ══════════════════════════════════════════════════════════════
# DEPLOYMENT NOTES
# ══════════════════════════════════════════════════════════════
# 1. Generate JWT secrets: openssl rand -base64 32
# 2. Use Supabase POOLED connection (port 6543) with pgbouncer=true
# 3. Update APP_URL and CORS_ORIGIN after deploying frontend to Vercel
# 4. Verify your Resend sending domain before enabling mail
# 5. Set up Redis (Upstash recommended for free tier)
# ══════════════════════════════════════════════════════════════
